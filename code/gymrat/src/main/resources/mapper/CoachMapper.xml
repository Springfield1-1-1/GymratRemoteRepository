<?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.springfield.gymrat.mapper.CoachMapper">

    <select id="selectByStoreId" resultType="com.springfield.gymrat.entity.Coach">
        SELECT * FROM coaches
        WHERE store_id = #{storeId} AND status = 1
        ORDER BY id ASC
    </select>

</mapper>
