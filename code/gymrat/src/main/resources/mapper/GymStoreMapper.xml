<?xml version="1.0" encoding="UTF-8"?>
        <!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.springfield.gymrat.mapper.GymStoreMapper">

    <select id="selectByCity" resultType="com.springfield.gymrat.entity.GymStore">
        SELECT * FROM gym_stores
        <where>
            status = 1
            <if test="city != null and city != ''">
                AND city = #{city}
            </if>
        </where>
        ORDER BY id ASC
    </select>

</mapper>
